# ==========================================
# Agents Learn 环境变量配置模板
# ==========================================

# ---------------------------------------------------------
# LLM 模型基础配置 (Model Configuration)
# ---------------------------------------------------------

# 推荐使用统一 provider 配置。
# 可选值：deepseek / openai / minimax / custom
LLM_PROVIDER=deepseek

# 统一模型名。未设置时会回退到 provider 专属模型名，再回退到旧 MODEL_NAME。
# DeepSeek 示例: deepseek-v4-flash, deepseek-v4-pro
# OpenAI 示例: gpt-4o-mini, gpt-4o
# MiniMax 示例: MiniMax-M2.7, MiniMax-M2.7-highspeed, MiniMax-M2.5, MiniMax-M2.1
LLM_MODEL=deepseek-v4-flash

# 统一 API 密钥和基础地址，可用于任意 OpenAI-compatible provider。
# 如果配置了 provider 专属变量，会优先使用 provider 专属变量。
LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=

# ---------------------------------------------------------
# DeepSeek 配置
# ---------------------------------------------------------

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# DeepSeek V4 思考模式开关
# - enabled: 思考模式
# - disabled: 非思考模式
# - 当前项目中的 Agent 示例默认建议使用 disabled，避免工具调用场景下的 reasoning_content 兼容问题
DEEPSEEK_THINKING=disabled

# 可选：仅在启用思考模式时生效
# DEEPSEEK_REASONING_EFFORT=high

# ---------------------------------------------------------
# MiniMax 配置
# ---------------------------------------------------------

# MiniMax 官方 OpenAI-compatible base URL:
# - 中国区: https://api.minimaxi.com/v1
# - 国际区: https://api.minimax.io/v1
# 对应接口: /chat/completions
# 官方模型示例: MiniMax-M2.7, MiniMax-M2.7-highspeed, MiniMax-M2.5, MiniMax-M2.1
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# ---------------------------------------------------------
# OpenAI 配置
# ---------------------------------------------------------

OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------
# 自定义 OpenAI-compatible 服务
# ---------------------------------------------------------

# LLM_PROVIDER=custom 时使用。适合本地 Ollama/vLLM/LMDeploy 或其他兼容网关。
# CUSTOM_LLM_API_KEY=your_custom_api_key
# CUSTOM_LLM_BASE_URL=http://localhost:8000/v1
# CUSTOM_LLM_MODEL=your-model-name
# CUSTOM_LLM_SUPPORTS_JSON_MODE=true

# ---------------------------------------------------------
# 旧变量兼容（仍可用，但新代码优先读取 LLM_* / provider 专属变量）
# ---------------------------------------------------------

# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.deepseek.com
# MODEL_NAME=deepseek-v4-flash

# ---------------------------------------------------------
# Langfuse 可观测性追踪配置 (替代原有 LangSmith)
# ---------------------------------------------------------
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com


TAVILY_API_KEY=
