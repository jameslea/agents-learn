# ==========================================
# Agents Learn 环境变量配置模板
# ==========================================

# ---------------------------------------------------------
# LLM 模型基础配置 (Model Configuration)
# ---------------------------------------------------------

# 统一使用的 API 密钥 (配置第三方兼容服务时，同样填入此项)
OPENAI_API_KEY=your_api_key_here

# API 接口的基础地址
# - 默认不配置时将指向 OpenAI 官方地址
# - DeepSeek 配置示例: https://api.deepseek.com
OPENAI_BASE_URL=https://api.deepseek.com

# 模型名称
# - OpenAI 示例: gpt-4o-mini, gpt-4o
# - DeepSeek 示例: deepseek-chat, deepseek-reasoner
MODEL_NAME=deepseek-chat

# ---------------------------------------------------------
# 独立集成方配置 (可选 / Specialized Integrations)
# ---------------------------------------------------------

# 专属 DeepSeek API 密钥
# (仅在代码中显式调用 LangChain 的 ChatDeepSeek 类时需要)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ---------------------------------------------------------
# Langfuse 可观测性追踪配置 (替代原有 LangSmith)
# ---------------------------------------------------------
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com


TAVILY_API_KEY=